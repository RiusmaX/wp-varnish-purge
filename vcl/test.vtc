varnishtest "Generic WP/PrestaShop VCL: cache, purge exact, purge regex, pass rules"

server s1 {
	# 1. first fetch of /page/ (miss)
	rxreq
	expect req.url == "/page/"
	txresp -hdr "Content-Type: text/html" -body "page-v1"

	# 2. first fetch of /other/ (miss)
	rxreq
	expect req.url == "/other/"
	txresp -hdr "Content-Type: text/html" -body "other-v1"

	# 3. logged-in user on /page/ bypasses the cache
	rxreq
	expect req.url == "/page/"
	expect req.http.Cookie ~ "wordpress_logged_in_"
	txresp -hdr "Content-Type: text/html" -body "page-private"

	# 4. refetch of /page/ after exact PURGE
	rxreq
	expect req.url == "/page/"
	txresp -hdr "Content-Type: text/html" -body "page-v2"

	# 5+6. refetch of both pages after regex PURGE of the whole host
	rxreq
	expect req.url == "/page/"
	txresp -hdr "Content-Type: text/html" -body "page-v3"
	rxreq
	expect req.url == "/other/"
	txresp -hdr "Content-Type: text/html" -body "other-v2"

	# 7+8. /wp-json is never cached: two requests, two fetches
	rxreq
	expect req.url == "/wp-json/wp/v2/pages"
	txresp -hdr "Content-Type: application/json" -body "json-1"
	rxreq
	expect req.url == "/wp-json/wp/v2/pages"
	txresp -hdr "Content-Type: application/json" -body "json-2"

	# 9. static file fetched once despite the client cookie (no cookie forwarded)
	rxreq
	expect req.url == "/style.css"
	expect req.http.Cookie == <undef>
	txresp -hdr "Content-Type: text/css" -hdr "Set-Cookie: junk=1" -body "css-v1"

	# 10. Set-Cookie page is never cached: second request refetches
	rxreq
	expect req.url == "/session/"
	txresp -hdr "Content-Type: text/html" -hdr "Set-Cookie: PHPSESSID=abc" -body "sess-1"
	rxreq
	expect req.url == "/session/"
	txresp -hdr "Content-Type: text/html" -hdr "Set-Cookie: PHPSESSID=def" -body "sess-2"

	# 11. Polylang language cookie is stripped and the page IS cached
	rxreq
	expect req.url == "/langue/"
	txresp -hdr "Content-Type: text/html" -hdr "Set-Cookie: pll_language=fr; path=/" -body "lang-1"

	# 12. self-redirect from the backend is delivered but NEVER cached:
	# two client requests must produce two backend fetches
	rxreq
	expect req.url == "/loop/"
	txresp -status 301 -hdr "Location: https://example.com/loop/"
	rxreq
	expect req.url == "/loop/"
	txresp -status 301 -hdr "Location: https://example.com/loop/"
} -start

varnish v1 -vcl+backend {
	${vcl_body}
} -start

client c1 {
	# --- basic caching: miss then hit, forced 1h TTL ---
	txreq -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "page-v1"
	expect resp.http.X-Cache == "MISS"
	expect resp.http.X-Cacheable == "YES:Forced"
	expect resp.http.x-url == <undef>
	expect resp.http.x-host == <undef>

	txreq -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "page-v1"
	expect resp.http.X-Cache == "HIT"

	txreq -url "/other/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "other-v1"
	expect resp.http.X-Cache == "MISS"

	# --- tracking params are stripped: same cache entry as /page/ ---
	txreq -url "/page/?utm_source=newsletter&fbclid=XYZ123" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "page-v1"
	expect resp.http.X-Cache == "HIT"

	# --- logged-in cookie bypasses the cache ---
	txreq -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https" -hdr "Cookie: wordpress_logged_in_abc=1"
	rxresp
	expect resp.body == "page-private"
	expect resp.http.X-Cacheable == "NO:Logged in/Got Sessions"

	# ...and did not poison the anonymous cache entry
	txreq -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "page-v1"
	expect resp.http.X-Cache == "HIT"

	# --- exact purge (no header) ---
	txreq -req "PURGE" -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.status == 200

	txreq -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "page-v2"
	expect resp.http.X-Cache == "MISS"

	# /other/ untouched by the exact purge
	txreq -url "/other/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "other-v1"
	expect resp.http.X-Cache == "HIT"

	# --- regex purge of the whole host ---
	txreq -req "PURGE" -url "/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https" -hdr "X-Purge-Method: regex"
	rxresp
	expect resp.status == 200

	txreq -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "page-v3"
	expect resp.http.X-Cache == "MISS"

	txreq -url "/other/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "other-v2"
	expect resp.http.X-Cache == "MISS"

	# --- REST API is never cached ---
	txreq -url "/wp-json/wp/v2/pages" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "json-1"
	expect resp.http.X-Cacheable == "NO:Logged in/Got Sessions"

	txreq -url "/wp-json/wp/v2/pages" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "json-2"

	# --- static file: cookie stripped, Set-Cookie dropped, cached ---
	txreq -url "/style.css" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https" -hdr "Cookie: wordpress_logged_in_abc=1"
	rxresp
	expect resp.body == "css-v1"
	expect resp.http.Set-Cookie == <undef>

	txreq -url "/style.css" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "css-v1"
	expect resp.http.X-Cache == "HIT"

	# --- backend Set-Cookie prevents caching (builtin fallthrough) ---
	txreq -url "/session/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "sess-1"
	expect resp.http.X-Cacheable == "NO:Got Cookies"

	txreq -url "/session/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "sess-2"
	expect resp.http.X-Cache == "MISS"

	# --- Polylang cookie stripped, page cached anyway ---
	txreq -url "/langue/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "lang-1"
	expect resp.http.Set-Cookie == <undef>
	expect resp.http.X-Cache == "MISS"

	txreq -url "/langue/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.body == "lang-1"
	expect resp.http.X-Cache == "HIT"

	# --- HTTPS redirect only when the front proxy says http ---
	txreq -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: http"
	rxresp
	expect resp.status == 301
	expect resp.http.Location == "https://example.com/page/"

	# --- self-redirect: delivered once, never cached (anti redirect-loop) ---
	txreq -url "/loop/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.status == 301
	expect resp.http.X-Cacheable == "NO:SelfRedirect"

	txreq -url "/loop/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.status == 301
	expect resp.http.X-Cache == "MISS"
} -run

client c2 {
	# Regression: a request with NO X-Forwarded-Proto at all must be
	# redirected by Varnish itself (synth), never reach the backend, and
	# never poison the cache for HTTPS visitors.
	txreq -url "/page/" -hdr "Host: example.com"
	rxresp
	expect resp.status == 301
	expect resp.http.Location == "https://example.com/page/"

	# The HTTPS variant is still served from cache, unpoisoned.
	txreq -url "/page/" -hdr "Host: example.com" -hdr "X-Forwarded-Proto: https"
	rxresp
	expect resp.status == 200
	expect resp.http.X-Cache == "HIT"
} -run
