"Plural-Forms: nplurals=2; plural=(n > 1);\n"

msgid "Varnish Cache"
msgstr "Cache Varnish"

msgid "Varnish cache purge"
msgstr "Purge du cache Varnish"

msgid "Purge this site"
msgstr "Purger ce site"

msgid "Purge the whole network"
msgstr "Purger tout le réseau"

msgid "Varnish Cache — Network"
msgstr "Cache Varnish — Réseau"

msgid "Global purge"
msgstr "Purge globale"

#. translators: %d: number of network domains
msgid "Purge the Varnish cache of all <strong>%d network domains</strong> at once."
msgstr "Purge le cache Varnish des <strong>%d domaines du réseau</strong> en une fois."

msgid "Purge all Varnish cache"
msgstr "Vider tout le cache Varnish"

msgid "Per-site purge (%d)"
msgstr "Purge par site (%d)"

msgid "Domain"
msgstr "Domaine"

msgid "Action"
msgstr "Action"

msgid "Purge"
msgstr "Purger"

msgid "URL trigger"
msgstr "Déclenchement par URL"

msgid "URL to call (curl, bookmark, scheduled task)."
msgstr "URL à appeler (curl, marque-page, tâche planifiée)."

msgid "Keep it secret."
msgstr "À garder secrète."

msgid "To purge <strong>a single site</strong>, append <code>&amp;host=DOMAIN</code>:"
msgstr "Pour purger <strong>un seul site</strong>, ajoutez <code>&amp;host=DOMAINE</code> :"

msgid "Regenerate the token? Existing URLs will stop working."
msgstr "Régénérer le jeton ? Les anciennes URL cesseront de fonctionner."

msgid "Regenerate token"
msgstr "Régénérer le jeton"

#. translators: %s: current site host
msgid "Purge this site's Varnish cache: %s"
msgstr "Purge le cache Varnish de ce site : %s"

msgid "Note: the cache of a page is purged automatically when its content is saved."
msgstr "Remarque : le cache d’une page est purgé automatiquement lorsque son contenu est enregistré."

msgid "Purge this site's cache"
msgstr "Vider le cache de ce site"

msgid "Action not allowed."
msgstr "Action non autorisée."

msgid "Unknown domain."
msgstr "Domaine inconnu."

msgid "the whole network"
msgstr "tout le réseau"

#. translators: 1: target label, 2: successful requests, 3: total requests
msgid "Varnish cache purged — %1$s. %2$d / %3$d PURGE requests succeeded."
msgstr "Cache Varnish vidé — %1$s. %2$d / %3$d requêtes PURGE réussies."
